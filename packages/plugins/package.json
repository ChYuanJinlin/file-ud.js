{
  "name": "@file-ud.js/plugins",
  "version": "0.1.1",
  "description": "Official plugins for file-ud.js upload and download workflows.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChYuanJinlin/file-ud.js.git",
    "directory": "packages/plugins"
  },
  "homepage": "https://chyuanjinlin.github.io/file-ud.js/",
  "bugs": {
    "url": "https://github.com/ChYuanJinlin/file-ud.js/issues"
  },
  "keywords": [
    "file-ud",
    "upload",
    "plugins",
    "validator",
    "compress",
    "watermark",
    "retry"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "src/uploader/*/README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.mjs"
    },
    "./uploader": {
      "types": "./dist/uploader/index.d.ts",
      "import": "./dist/uploader/index.mjs",
      "require": "./dist/uploader/index.js",
      "default": "./dist/uploader/index.mjs"
    },
    "./downloader": {
      "types": "./dist/downloader/index.d.ts",
      "import": "./dist/downloader/index.mjs",
      "require": "./dist/downloader/index.js",
      "default": "./dist/downloader/index.mjs"
    },
    "./retry": {
      "types": "./dist/retry/index.d.ts",
      "import": "./dist/retry/index.mjs",
      "require": "./dist/retry/index.js",
      "default": "./dist/retry/index.mjs"
    }
  },
  "devDependencies": {
    "@file-ud.js/core": "workspace:^",
    "tsup": "^7.2.0",
    "typescript": "^5.2.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "peerDependencies": {
    "@file-ud.js/core": ">=0.0.0 <1.0.0"
  },
  "dependencies": {
    "axios": "^1.13.6"
  }
}
